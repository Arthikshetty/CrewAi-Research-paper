# === LLM ===
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=                    # Leave empty for OpenAI. For NVIDIA: https://integrate.api.nvidia.com/v1

# === Academic Source APIs ===
SEMANTIC_SCHOLAR_API_KEY=           # Optional, improves rate limits
IEEE_API_KEY=                       # Free academic registration at developer.ieee.org
ELSEVIER_API_KEY=                   # Covers Scopus + ScienceDirect (dev.elsevier.com)
WOS_API_KEY=                        # Optional — requires paid institutional access
OPENALEX_EMAIL=you@university.edu   # Polite pool for better rate limits
CORE_API_KEY=                       # Optional, register at core.ac.uk
NCBI_API_KEY=                       # Optional, register at ncbi.nlm.nih.gov
SERPAPI_KEY=                        # Optional — for Google Scholar ($)

# === Neo4j ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# === LLM Model Selection ===
LLM_MODEL=gpt-4o-mini                  # Or: qwen/qwen3-235b-a22b (NVIDIA)
LLM_MODEL_SUMMARIZATION=gpt-4o         # Or: qwen/qwen3-235b-a22b (NVIDIA)
